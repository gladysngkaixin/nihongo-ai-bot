# ============================================================
# Nihongo.AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# On Railway, set these in the Variables tab instead.
# ============================================================

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Admin Chat IDs — comma-separated Telegram user IDs
# These users can use /reset_today to regenerate the daily quiz.
# To find your chat ID, message @userinfobot on Telegram.
ADMIN_CHAT_IDS=245478199

# (Optional) OpenAI model to use — defaults to gpt-4.1-mini
# OPENAI_MODEL=gpt-4.1-mini

# (Optional) Log level — defaults to INFO
# LOG_LEVEL=INFO

# (Optional) Data directory for SQLite database — defaults to current directory
# DATA_DIR=.
